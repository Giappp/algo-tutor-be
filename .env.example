# ===================================================================
# AlgoTutor Backend - Environment Configuration Template
# Copy this file to '.env' and fill in your actual credentials.
# DO NOT commit '.env' to git repository.
# ===================================================================

# JWT Configuration
# Generate a secure random 256-bit key (Base64) for JWT signing
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION_MS=900000

# Database Configuration (PostgreSQL)
# Used directly when running application locally. In Docker, these are wired automatically.
DATABASE_URL=jdbc:postgresql://localhost:5432/onlinejudge
DATABASE_USERNAME=ojuser
DATABASE_PASSWORD=ojpass

# Redis Configuration (Caching)
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ Configuration (Message Queue)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=ojuser
RABBITMQ_PASSWORD=ojpass

# AWS S3 Cloud Storage Credentials
AWS_ACCESS_KEY=your_aws_access_key_here
AWS_SECRET_KEY=your_aws_secret_key_here
AWS_REGION=ap-southeast-2
AWS_BUCKET_NAME=your_s3_bucket_name_here

# Artificial Intelligence Model Keys (Spring AI)
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# PISTON
PISTON_API_URL=http://judge:2000
